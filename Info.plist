<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Nasconde l'icona dal Dock — gira solo nella menu bar -->
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>CFBundleName</key>
    <string>DockDock</string>
    <key>CFBundleIconFile</key>
    <string>DockDock</string>
    <key>CFBundleIdentifier</key>
    <string>com.alBz.DockDock</string>
    <key>CFBundleVersion</key>
    <string>3</string>
    <key>CFBundleShortVersionString</key>
    <string>0.2.1</string>
    <!-- Descrizioni per i dialog di permesso sistema -->
    <key>NSAccessibilityUsageDescription</key>
    <string>DockDock needs accessibility access to detect which app icon you're hovering in the Dock and to manage windows.</string>
    <key>NSScreenCaptureDescription</key>
    <string>DockDock needs screen recording access to generate window previews.</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>DockDock needs permission to control Spotify for playback controls and to read the current track.</string>
</dict>
</plist>
